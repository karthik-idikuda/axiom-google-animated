# AXIOM Frontend Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
#
# These are the PUBLIC Firebase web-app config keys (client-side SDK).
# NOT the server-side service account — those live in backend/.env

# Backend API URL — change to your Cloud Run URL in production
REACT_APP_API_URL=http://localhost:8000

# Firebase Web App Config (from Firebase Console → Project Settings → Web Apps)
REACT_APP_FIREBASE_API_KEY=your-web-api-key
REACT_APP_FIREBASE_AUTH_DOMAIN=axiom-conscience.firebaseapp.com
REACT_APP_FIREBASE_DATABASE_URL=https://axiom-conscience-default-rtdb.firebaseio.com
REACT_APP_FIREBASE_PROJECT_ID=axiom-conscience
REACT_APP_FIREBASE_STORAGE_BUCKET=axiom-conscience.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=342907906934
REACT_APP_FIREBASE_APP_ID=1:342907906934:web:your-app-id
